            "value": "{{user_agent}}",
            "type": "text"
          }
        ],
        "url": {
          "raw": "{{base_url}}/v1/responses",
          "host": [
            "{{base_url}}"
          ],
          "path": [
            "v1",
            "responses"
          ]
        },
        "description": "POST /v1/responses. Set new_session=true or header X-New-Session:true to start a fresh ChatGPT conversation.",
        "body": {
          "mode": "raw",
          "raw": "{\n  \"model\": \"{{model}}\",\n  \"input\": \"Say exactly: pong\",\n  \"stream\": false,\n  \"new_session\": false\n}",
          "options": {
            "raw": {
              "language": "json"
            }
          }
        }
      },
      "event": [
        {
          "listen": "test",
          "script": {
            "type": "text/javascript",
            "exec": [
              "pm.test('status is 200', function () { pm.response.to.have.status(200); });",
              "pm.test('responses shape', function () { const j = pm.response.json(); pm.expect(j.object).to.eql('response'); pm.expect(j.output_text).to.be.a('string'); });"
            ]
          }
        }
